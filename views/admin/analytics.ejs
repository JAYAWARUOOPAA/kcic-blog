<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="/public/css/style.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
</head>
<body>
<div class="admin-layout">
  <%- include('../partials/admin-sidebar', { user, currentPage }) %>
  <div class="admin-main">
    <div class="admin-topbar">
      <div class="d-flex align-items-center gap-3">
        <button class="btn btn-sm btn-outline-secondary d-lg-none" id="sidebarToggleBtn"><i class="fas fa-bars"></i></button>
        <h5><i class="fas fa-chart-bar me-2"></i>Analytics Dashboard</h5>
      </div>
      <span class="text-muted" style="font-size:13px"><i class="fas fa-sync me-1"></i>Live Data</span>
    </div>
    <div class="admin-content">

      <!-- Summary Stats -->
      <div class="row g-4 mb-5">
        <div class="col-6 col-lg-2">
          <div class="stat-card text-center flex-column p-3">
            <div class="stat-icon mx-auto mb-2" style="background:linear-gradient(135deg,var(--primary),var(--primary-light))"><i class="fas fa-newspaper"></i></div>
            <div class="stat-value" style="font-size:22px"><%= stats.total_published||0 %></div>
            <div class="stat-label" style="font-size:11px">Published</div>
          </div>
        </div>
        <div class="col-6 col-lg-2">
          <div class="stat-card text-center flex-column p-3">
            <div class="stat-icon mx-auto mb-2" style="background:linear-gradient(135deg,#f59e0b,#d97706)"><i class="fas fa-clock"></i></div>
            <div class="stat-value" style="font-size:22px"><%= stats.total_pending||0 %></div>
            <div class="stat-label" style="font-size:11px">Pending</div>
          </div>
        </div>
        <div class="col-6 col-lg-2">
          <div class="stat-card text-center flex-column p-3">
            <div class="stat-icon mx-auto mb-2" style="background:linear-gradient(135deg,var(--success),#14532d)"><i class="fas fa-users"></i></div>
            <div class="stat-value" style="font-size:22px"><%= stats.total_users||0 %></div>
            <div class="stat-label" style="font-size:11px">Users</div>
          </div>
        </div>
        <div class="col-6 col-lg-2">
          <div class="stat-card text-center flex-column p-3">
            <div class="stat-icon mx-auto mb-2" style="background:linear-gradient(135deg,#8b5cf6,#5b21b6)"><i class="fas fa-eye"></i></div>
            <div class="stat-value" style="font-size:22px"><%= parseInt(stats.total_views||0).toLocaleString() %></div>
            <div class="stat-label" style="font-size:11px">Total Views</div>
          </div>
        </div>
        <div class="col-6 col-lg-2">
          <div class="stat-card text-center flex-column p-3">
            <div class="stat-icon mx-auto mb-2" style="background:linear-gradient(135deg,#ec4899,#be185d)"><i class="fas fa-comments"></i></div>
            <div class="stat-value" style="font-size:22px"><%= stats.total_comments||0 %></div>
            <div class="stat-label" style="font-size:11px">Comments</div>
          </div>
        </div>
        <div class="col-6 col-lg-2">
          <div class="stat-card text-center flex-column p-3">
            <div class="stat-icon mx-auto mb-2" style="background:linear-gradient(135deg,#f97316,#c2410c)"><i class="fas fa-heart"></i></div>
            <div class="stat-value" style="font-size:22px"><%= stats.total_likes||0 %></div>
            <div class="stat-label" style="font-size:11px">Total Likes</div>
          </div>
        </div>
      </div>

      <!-- Charts Row -->
      <div class="row g-4 mb-5">
        <!-- Daily Views Chart -->
        <div class="col-lg-8">
          <div class="bg-white rounded-3 shadow-sm p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
              <h6 style="font-family:var(--font-display);font-weight:700;color:var(--primary)" class="mb-0"><i class="fas fa-chart-line me-2"></i>Daily Views (Last 30 Days)</h6>
              <span class="badge bg-light text-dark"><%= dailyViews.length %> days with data</span>
            </div>
            <div style="height:260px;position:relative">
              <canvas id="viewsChart"
                data-labels='<%= JSON.stringify(dailyViews.map(d => new Date(d.date).toLocaleDateString("en-US",{month:"short",day:"numeric"}))) %>'
                data-values='<%= JSON.stringify(dailyViews.map(d => parseInt(d.views)||0)) %>'>
              </canvas>
              <% if(dailyViews.length===0){ %>
              <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:var(--text-muted);font-size:14px">
                <div class="text-center"><i class="fas fa-chart-line d-block mb-2" style="font-size:32px;opacity:0.3"></i>No view data yet</div>
              </div>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Category Distribution -->
        <div class="col-lg-4">
          <div class="bg-white rounded-3 shadow-sm p-4">
            <h6 style="font-family:var(--font-display);font-weight:700;color:var(--primary)" class="mb-4"><i class="fas fa-chart-pie me-2"></i>Articles by Category</h6>
            <div style="height:220px;position:relative">
              <canvas id="categoryChart"
                data-labels='<%= JSON.stringify(categoryStats.map(c => c.name)) %>'
                data-values='<%= JSON.stringify(categoryStats.map(c => parseInt(c.article_count)||0)) %>'
                data-colors='<%= JSON.stringify(categoryStats.map(c => c.color||"#1a3c5e")) %>'>
              </canvas>
              <% if(categoryStats.length===0){ %>
              <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:var(--text-muted);font-size:14px">
                <div class="text-center"><i class="fas fa-chart-pie d-block mb-2" style="font-size:32px;opacity:0.3"></i>No data</div>
              </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <!-- Top Articles & Category Stats -->
      <div class="row g-4">
        <!-- Top Articles -->
        <div class="col-lg-8">
          <div class="admin-table">
            <div class="admin-table-header">
              <h6><i class="fas fa-trophy me-2 text-warning"></i>Top Performing Articles</h6>
            </div>
            <% if(topArticles.length===0){ %>
            <div class="empty-state p-4 text-center"><p class="text-muted">No published articles yet.</p></div>
            <% } else { %>
            <div class="table-responsive">
              <table class="table">
                <thead><tr><th>#</th><th>Article</th><th>Category</th><th>Views</th><th>Likes</th><th>Comments</th></tr></thead>
                <tbody>
                <% topArticles.forEach((art, i) => { %>
                <tr>
                  <td>
                    <span class="badge <%= i===0?'bg-warning text-dark':i===1?'bg-secondary':i===2?'':'bg-light text-dark border' %>">
                      <%= i===0?'🥇':i===1?'🥈':i===2?'🥉':`#${i+1}` %>
                    </span>
                  </td>
                  <td>
                    <a href="/article/<%= art.slug %>" target="_blank" class="text-decoration-none fw-500" style="font-size:13px;color:var(--text-dark)">
                      <%= art.title.substring(0,60)+(art.title.length>60?'...':'') %>
                    </a>
                    <div class="text-muted" style="font-size:11px"><%= art.first_name %> <%= art.last_name %></div>
                  </td>
                  <td><small class="text-muted"><%= art.category_name||'—' %></small></td>
                  <td>
                    <div class="d-flex align-items-center gap-1">
                      <div style="width:<%= Math.min(60, Math.round((art.views / Math.max(...topArticles.map(a=>a.views))) * 60)) %>px;height:6px;background:var(--primary);border-radius:3px"></div>
                      <strong style="font-size:13px"><%= art.views %></strong>
                    </div>
                  </td>
                  <td><span class="text-danger"><i class="fas fa-heart me-1"></i><%= art.likes %></span></td>
                  <td><span class="text-muted"><i class="fas fa-comment me-1"></i><%= art.comments %></span></td>
                </tr>
                <% }) %>
                </tbody>
              </table>
            </div>
            <% } %>
          </div>
        </div>

        <!-- Category Stats -->
        <div class="col-lg-4">
          <div class="bg-white rounded-3 shadow-sm p-4">
            <h6 style="font-family:var(--font-display);font-weight:700;color:var(--primary)" class="mb-4"><i class="fas fa-tags me-2"></i>Category Performance</h6>
            <% if(categoryStats.length===0){ %>
            <div class="empty-state text-center p-3"><p class="text-muted">No categories yet.</p></div>
            <% } else { %>
            <% categoryStats.forEach(cat => { %>
            <div class="mb-3">
              <div class="d-flex justify-content-between mb-1">
                <div class="d-flex align-items-center gap-2">
                  <div style="width:10px;height:10px;border-radius:50%;background:<%= cat.color||'var(--primary)' %>"></div>
                  <span style="font-size:13px;font-weight:500"><%= cat.name %></span>
                </div>
                <span style="font-size:12px;color:var(--text-muted)"><%= cat.article_count %> articles · <%= parseInt(cat.total_views||0).toLocaleString() %> views</span>
              </div>
              <div style="height:6px;background:#f0f0f0;border-radius:3px">
                <div style="width:<%= categoryStats[0].article_count > 0 ? Math.round((cat.article_count / categoryStats[0].article_count) * 100) : 0 %>%;height:100%;background:<%= cat.color||'var(--primary)' %>;border-radius:3px;transition:width 0.5s"></div>
              </div>
            </div>
            <% }) %>
            <% } %>
          </div>

          <!-- User Growth -->
          <div class="bg-white rounded-3 shadow-sm p-4 mt-4">
            <h6 style="font-family:var(--font-display);font-weight:700;color:var(--primary)" class="mb-4"><i class="fas fa-user-plus me-2"></i>User Registrations</h6>
            <% if(userGrowth.length===0){ %>
            <div class="text-center text-muted p-3"><i class="fas fa-users" style="font-size:28px;opacity:0.3"></i><p class="mt-2" style="font-size:13px">No user data</p></div>
            <% } else { %>
            <% userGrowth.slice(0,6).forEach(row => { %>
            <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
              <span style="font-size:13px"><%= new Date(row.month).toLocaleDateString('en-US',{year:'numeric',month:'short'}) %></span>
              <div class="d-flex align-items-center gap-2">
                <div style="width:<%= Math.min(80, Math.round((row.count / Math.max(...userGrowth.map(r=>r.count))) * 80)) %>px;height:6px;background:var(--success);border-radius:3px"></div>
                <strong style="font-size:13px;color:var(--success)"><%= row.count %> new</strong>
              </div>
            </div>
            <% }) %>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/public/js/main.js"></script>
</body>
</html>
