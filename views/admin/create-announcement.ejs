<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="/public/css/style.css" rel="stylesheet">
</head>
<body>
<div class="admin-layout">
  <%- include('../partials/admin-sidebar', { user, currentPage }) %>
  <div class="admin-main">
    <div class="admin-topbar">
      <div class="d-flex align-items-center gap-3">
        <button class="btn btn-sm btn-outline-secondary d-lg-none" id="sidebarToggleBtn"><i class="fas fa-bars"></i></button>
        <h5><i class="fas fa-plus-circle me-2"></i>Create Announcement</h5>
      </div>
      <a href="/admin/announcements" class="btn btn-sm btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Back</a>
    </div>
    <div class="admin-content">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <% if(error){%><div class="alert alert-danger mb-4"><i class="fas fa-exclamation-circle me-2"></i><%= error %></div><%}%>

          <div class="bg-white rounded-3 shadow-sm p-4">
            <h6 style="font-family:var(--font-display);font-weight:700;color:var(--primary)" class="mb-4"><i class="fas fa-bullhorn me-2"></i>New Announcement</h6>
            <form action="/admin/announcements/create" method="POST">
              <div class="mb-4">
                <label class="form-label fw-600">Announcement Title <span class="text-danger">*</span></label>
                <input type="text" name="title" class="form-control form-control-lg" placeholder="e.g. Campus Closure Notice, Exam Schedule Update..." required maxlength="500">
              </div>
              <div class="mb-4">
                <label class="form-label fw-600">Content / Message <span class="text-danger">*</span></label>
                <textarea name="content" class="form-control" rows="6" placeholder="Write the full announcement message here..." required></textarea>
              </div>
              <div class="row g-3 mb-4">
                <div class="col-md-4">
                  <label class="form-label fw-600">Priority Level</label>
                  <select name="priority" class="form-select" id="prioritySelect" onchange="updatePreview()">
                    <option value="low">🟢 Low</option>
                    <option value="normal" selected>🔵 Normal</option>
                    <option value="high">🟡 High</option>
                    <option value="urgent">🔴 Urgent</option>
                  </select>
                  <div class="form-text">Urgent shows in red banner at top of site.</div>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-600">Target Audience</label>
                  <select name="target_role" class="form-select">
                    <option value="all">👥 Everyone</option>
                    <option value="user">👨‍🎓 Students Only</option>
                    <option value="admin">🛡️ Admins Only</option>
                  </select>
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-600">Expiry Date (optional)</label>
                  <input type="datetime-local" name="expires_at" class="form-control">
                  <div class="form-text">Leave blank for no expiry.</div>
                </div>
              </div>

              <!-- Preview -->
              <div class="mb-4">
                <label class="form-label fw-600"><i class="fas fa-eye me-1"></i>Preview</label>
                <div id="announcementPreview" class="announcement-banner normal p-3 rounded-3" style="border-left:4px solid var(--primary)">
                  <strong class="d-block mb-1">Your announcement title will appear here</strong>
                  <span class="text-muted" style="font-size:13px">Your message will appear here...</span>
                </div>
              </div>

              <div class="d-flex gap-3">
                <button type="submit" class="btn btn-primary px-5 py-2"><i class="fas fa-paper-plane me-2"></i>Publish Announcement</button>
                <a href="/admin/announcements" class="btn btn-outline-secondary px-5 py-2"><i class="fas fa-times me-2"></i>Cancel</a>
              </div>
            </form>
          </div>
        </div>

        <div class="col-lg-4">
          <div class="bg-white rounded-3 shadow-sm p-4">
            <h6 style="font-family:var(--font-display);font-weight:700;color:var(--primary)" class="mb-3"><i class="fas fa-info-circle me-2"></i>Priority Guide</h6>
            <div class="d-flex flex-column gap-3">
              <div class="p-3 rounded-3" style="border-left:4px solid var(--success);background:#f0fff4"><strong class="text-success">Low</strong><p class="mb-0 mt-1" style="font-size:13px">General info, minor updates, optional reading.</p></div>
              <div class="p-3 rounded-3" style="border-left:4px solid var(--primary);background:#f0f7ff"><strong style="color:var(--primary)">Normal</strong><p class="mb-0 mt-1" style="font-size:13px">Standard announcements, event reminders.</p></div>
              <div class="p-3 rounded-3" style="border-left:4px solid #f59e0b;background:#fffbeb"><strong style="color:#92400e">High</strong><p class="mb-0 mt-1" style="font-size:13px">Important deadlines, schedule changes.</p></div>
              <div class="p-3 rounded-3" style="border-left:4px solid var(--danger);background:#fff5f5"><strong class="text-danger">Urgent</strong><p class="mb-0 mt-1" style="font-size:13px">Critical alerts, emergency notices, closures.</p></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/public/js/main.js"></script>
<script>
const priorityColors = { low:'var(--success)', normal:'var(--primary)', high:'#f59e0b', urgent:'var(--danger)' };
const priorityBg = { low:'#f0fff4', normal:'#f0f7ff', high:'#fffbeb', urgent:'#fff5f5' };
function updatePreview() {
  const p = document.getElementById('prioritySelect').value;
  const preview = document.getElementById('announcementPreview');
  preview.style.borderLeftColor = priorityColors[p];
  preview.style.background = priorityBg[p];
}
document.querySelector('input[name="title"]')?.addEventListener('input', function() {
  document.querySelector('#announcementPreview strong').textContent = this.value || 'Your announcement title will appear here';
});
document.querySelector('textarea[name="content"]')?.addEventListener('input', function() {
  document.querySelector('#announcementPreview span').textContent = this.value.substring(0,100) || 'Your message will appear here...';
});
</script>
</body>
</html>
