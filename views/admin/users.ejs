<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="/public/css/style.css" rel="stylesheet">
</head>
<body>
<div class="admin-layout">
  <%- include('../partials/admin-sidebar', { user, currentPage }) %>
  <div class="admin-main">
    <div class="admin-topbar">
      <div class="d-flex align-items-center gap-3">
        <button class="btn btn-sm btn-outline-secondary d-lg-none" id="sidebarToggleBtn"><i class="fas fa-bars"></i></button>
        <h5><i class="fas fa-users me-2"></i>Manage Users</h5>
      </div>
      <a href="/admin/dashboard" class="btn btn-sm btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Dashboard</a>
    </div>
    <div class="admin-content">
      <% if(success){%><div class="alert alert-success alert-auto-dismiss mb-4"><i class="fas fa-check-circle me-2"></i><%= success %></div><%}%>

      <!-- Filters -->
      <div class="bg-white rounded-3 shadow-sm p-4 mb-4">
        <form action="/admin/users" method="GET" class="row g-3 align-items-end">
          <div class="col-md-5">
            <label class="form-label fw-600" style="font-size:13px">Search Users</label>
            <input type="text" name="search" class="form-control" value="<%= search %>" placeholder="Name, email, or username...">
          </div>
          <div class="col-md-3">
            <label class="form-label fw-600" style="font-size:13px">Role</label>
            <select name="role" class="form-select">
              <option value="all" <%=currentRole==='all'?'selected':''%>>All Roles</option>
              <option value="user" <%=currentRole==='user'?'selected':''%>>Students / Users</option>
              <option value="admin" <%=currentRole==='admin'?'selected':''%>>Administrators</option>
            </select>
          </div>
          <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100"><i class="fas fa-filter me-1"></i>Filter</button>
          </div>
          <div class="col-md-2">
            <a href="/admin/users" class="btn btn-outline-secondary w-100"><i class="fas fa-times me-1"></i>Clear</a>
          </div>
        </form>
      </div>

      <div class="admin-table">
        <div class="admin-table-header">
          <h6><i class="fas fa-users me-2"></i>Users (<%= pagination.total %>)</h6>
          <small class="text-muted">Page <%= pagination.page %> of <%= pagination.totalPages %></small>
        </div>
        <% if(users.length===0){ %>
        <div class="empty-state p-5 text-center">
          <i class="fas fa-users d-block mb-3" style="font-size:48px;color:var(--border)"></i>
          <h6>No Users Found</h6>
        </div>
        <% } else { %>
        <div class="table-responsive">
          <table class="table">
            <thead>
              <tr>
                <th>User</th>
                <th>Role</th>
                <th>Department</th>
                <th>Articles</th>
                <th>Status</th>
                <th>Joined</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
            <% users.forEach(u => { %>
            <tr class="<%= !u.is_active ? 'table-secondary' : '' %>">
              <td>
                <div class="d-flex align-items-center gap-3">
                  <div style="width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,var(--primary),var(--primary-light));color:white;display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:700;flex-shrink:0;opacity:<%=u.is_active?1:0.4%>">
                    <%= (u.first_name||'U')[0] %>
                  </div>
                  <div>
                    <div class="fw-500" style="font-size:13px"><%= u.first_name %> <%= u.last_name %></div>
                    <div class="text-muted" style="font-size:11px">@<%= u.username %></div>
                    <div class="text-muted" style="font-size:11px"><%= u.email %></div>
                  </div>
                </div>
              </td>
              <td>
                <span class="badge bg-<%= u.role==='admin'?'danger':'primary' %>">
                  <i class="fas fa-<%= u.role==='admin'?'shield-alt':'user-graduate' %> me-1"></i><%= u.role %>
                </span>
              </td>
              <td><small class="text-muted"><%= u.department||'—' %></small></td>
              <td>
                <span class="badge bg-light text-dark border"><i class="fas fa-file-alt me-1"></i><%= u.article_count||0 %></span>
              </td>
              <td>
                <span class="badge <%= u.is_active ? 'bg-success' : 'bg-secondary' %>">
                  <i class="fas fa-<%= u.is_active?'check':'times' %> me-1"></i><%= u.is_active ? 'Active' : 'Inactive' %>
                </span>
              </td>
              <td><small class="text-muted"><%= new Date(u.created_at).toLocaleDateString() %></small></td>
              <td>
                <div class="d-flex gap-1 flex-wrap">
                  <!-- Toggle Active -->
                  <form action="/admin/users/<%= u.id %>/toggle" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-sm <%= u.is_active?'btn-outline-warning':'btn-outline-success' %>"
                      data-confirm="<%= u.is_active?'Deactivate':'Activate' %> this user?"
                      title="<%= u.is_active?'Deactivate':'Activate' %>">
                      <i class="fas fa-<%= u.is_active?'ban':'check' %>"></i>
                    </button>
                  </form>
                  <!-- Change Role -->
                  <% if(u.id !== user.id){ %>
                  <form action="/admin/users/<%= u.id %>/role" method="POST" class="d-inline">
                    <select name="role" class="form-select form-select-sm d-inline" style="width:auto;font-size:12px" onchange="this.form.submit()">
                      <option value="user" <%=u.role==='user'?'selected':''%>>User</option>
                      <option value="admin" <%=u.role==='admin'?'selected':''%>>Admin</option>
                    </select>
                  </form>
                  <% } %>
                </div>
              </td>
            </tr>
            <% }) %>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <% if(pagination.totalPages > 1){ %>
        <div class="p-3 border-top d-flex justify-content-between align-items-center">
          <small class="text-muted">Showing <%= (pagination.page-1)*15+1 %>–<%= Math.min(pagination.page*15,pagination.total) %> of <%= pagination.total %></small>
          <nav><ul class="pagination pagination-sm mb-0">
            <li class="page-item <%=pagination.page===1?'disabled':''%>"><a class="page-link" href="?page=<%=pagination.page-1%>&role=<%=currentRole%>&search=<%=search%>"><i class="fas fa-chevron-left"></i></a></li>
            <% for(let i=1;i<=pagination.totalPages;i++){if(Math.abs(i-pagination.page)<=2||i===1||i===pagination.totalPages){ %>
            <li class="page-item <%=pagination.page===i?'active':''%>"><a class="page-link" href="?page=<%=i%>&role=<%=currentRole%>&search=<%=search%>"><%=i%></a></li>
            <%}else if(Math.abs(i-pagination.page)===3){%><li class="page-item disabled"><span class="page-link">...</span></li><%}}%>
            <li class="page-item <%=pagination.page===pagination.totalPages?'disabled':''%>"><a class="page-link" href="?page=<%=pagination.page+1%>&role=<%=currentRole%>&search=<%=search%>"><i class="fas fa-chevron-right"></i></a></li>
          </ul></nav>
        </div>
        <% } %>
        <% } %>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/public/js/main.js"></script>
</body>
</html>
