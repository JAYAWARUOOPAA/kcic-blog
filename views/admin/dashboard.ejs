<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="/public/css/style.css" rel="stylesheet">
</head>
<body>
<div class="admin-layout">
  <%- include('../partials/admin-sidebar', { user, currentPage }) %>
  <div class="admin-main">
    <!-- Top Bar -->
    <div class="admin-topbar">
      <div class="d-flex align-items-center gap-3">
        <button class="btn btn-sm btn-outline-secondary d-lg-none" id="sidebarToggleBtn"><i class="fas fa-bars"></i></button>
        <h5><i class="fas fa-tachometer-alt me-2"></i>Admin Dashboard</h5>
      </div>
      <div class="d-flex align-items-center gap-3">
        <a href="/articles" class="btn btn-sm btn-outline-primary" target="_blank"><i class="fas fa-globe me-1"></i>View Site</a>
        <span class="text-muted" style="font-size:13px"><i class="fas fa-clock me-1"></i><%= new Date().toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric'}) %></span>
      </div>
    </div>
    <div class="admin-content">

      <!-- Stats Row -->
      <div class="row g-4 mb-5">
        <div class="col-6 col-lg-3">
          <div class="stat-card">
            <div class="stat-icon" style="background:linear-gradient(135deg,var(--primary),var(--primary-light))"><i class="fas fa-newspaper"></i></div>
            <div>
              <div class="stat-value"><%= stats.published_articles||0 %></div>
              <div class="stat-label">Published Articles</div>
            </div>
          </div>
        </div>
        <div class="col-6 col-lg-3">
          <div class="stat-card">
            <div class="stat-icon" style="background:linear-gradient(135deg,#f59e0b,#d97706)"><i class="fas fa-clock"></i></div>
            <div>
              <div class="stat-value"><%= stats.pending_articles||0 %></div>
              <div class="stat-label">Pending Review</div>
              <% if(stats.pending_articles>0){%><div class="stat-change up"><i class="fas fa-exclamation-circle me-1"></i>Needs attention</div><%}%>
            </div>
          </div>
        </div>
        <div class="col-6 col-lg-3">
          <div class="stat-card">
            <div class="stat-icon" style="background:linear-gradient(135deg,var(--success),#14532d)"><i class="fas fa-users"></i></div>
            <div>
              <div class="stat-value"><%= stats.total_students||0 %></div>
              <div class="stat-label">Registered Students</div>
            </div>
          </div>
        </div>
        <div class="col-6 col-lg-3">
          <div class="stat-card">
            <div class="stat-icon" style="background:linear-gradient(135deg,#8b5cf6,#5b21b6)"><i class="fas fa-eye"></i></div>
            <div>
              <div class="stat-value"><%= parseInt(stats.total_views||0).toLocaleString() %></div>
              <div class="stat-label">Total Views</div>
            </div>
          </div>
        </div>
        <div class="col-6 col-lg-3">
          <div class="stat-card">
            <div class="stat-icon" style="background:linear-gradient(135deg,#ec4899,#be185d)"><i class="fas fa-comments"></i></div>
            <div><div class="stat-value"><%= stats.total_comments||0 %></div><div class="stat-label">Total Comments</div></div>
          </div>
        </div>
        <div class="col-6 col-lg-3">
          <div class="stat-card">
            <div class="stat-icon" style="background:linear-gradient(135deg,#06b6d4,#0e7490)"><i class="fas fa-tags"></i></div>
            <div><div class="stat-value"><%= stats.total_categories||0 %></div><div class="stat-label">Categories</div></div>
          </div>
        </div>
        <div class="col-6 col-lg-3">
          <div class="stat-card">
            <div class="stat-icon" style="background:linear-gradient(135deg,#10b981,#059669)"><i class="fas fa-user-shield"></i></div>
            <div><div class="stat-value"><%= stats.total_users||0 %></div><div class="stat-label">Total Users</div></div>
          </div>
        </div>
        <div class="col-6 col-lg-3">
          <div class="stat-card">
            <div class="stat-icon" style="background:linear-gradient(135deg,#f97316,#c2410c)"><i class="fas fa-bullhorn"></i></div>
            <div><div class="stat-value"><%= stats.active_announcements||0 %></div><div class="stat-label">Active Announcements</div></div>
          </div>
        </div>
      </div>

      <div class="row g-4">
        <!-- Pending Articles - PRIORITY -->
        <div class="col-lg-6">
          <div class="admin-table">
            <div class="admin-table-header">
              <h6><i class="fas fa-clock me-2 text-warning"></i>Pending Review</h6>
              <a href="/admin/articles?status=pending" class="btn btn-sm btn-warning text-white">View All</a>
            </div>
            <% if (pendingArticles.length === 0) { %>
            <div class="empty-state p-4"><i class="fas fa-check-circle text-success d-block mb-2" style="font-size:28px"></i><p class="text-success mb-0">No articles pending review!</p></div>
            <% } else { %>
            <div class="table-responsive">
              <table class="table mb-0">
                <thead><tr><th>Title</th><th>Author</th><th>Date</th><th>Action</th></tr></thead>
                <tbody>
                <% pendingArticles.forEach(art => { %>
                <tr>
                  <td><div style="max-width:200px;font-size:13px;font-weight:500"><%= art.title.substring(0,50)+(art.title.length>50?'...':'') %></div></td>
                  <td><small><%= art.first_name %> <%= art.last_name %></small></td>
                  <td><small class="text-muted"><%= new Date(art.created_at).toLocaleDateString() %></small></td>
                  <td>
                    <a href="/admin/articles/<%= art.id %>/review" class="btn btn-xs btn-primary p-1 px-2" style="font-size:12px"><i class="fas fa-eye me-1"></i>Review</a>
                  </td>
                </tr>
                <% }) %>
                </tbody>
              </table>
            </div>
            <% } %>
          </div>
        </div>

        <!-- Recent Users -->
        <div class="col-lg-6">
          <div class="admin-table">
            <div class="admin-table-header">
              <h6><i class="fas fa-user-plus me-2"></i>Recent Registrations</h6>
              <a href="/admin/users" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="table-responsive">
              <table class="table mb-0">
                <thead><tr><th>User</th><th>Role</th><th>Joined</th></tr></thead>
                <tbody>
                <% recentUsers.forEach(u => { %>
                <tr>
                  <td>
                    <div class="d-flex align-items-center gap-2">
                      <div style="width:32px;height:32px;border-radius:50%;background:var(--primary);color:white;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0"><%= (u.first_name||'U')[0] %></div>
                      <div>
                        <div style="font-size:13px;font-weight:500"><%= u.first_name %> <%= u.last_name %></div>
                        <div style="font-size:11px;color:var(--text-muted)"><%= u.email %></div>
                      </div>
                    </div>
                  </td>
                  <td><span class="badge bg-<%= u.role==='admin'?'danger':'primary' %>"><%= u.role %></span></td>
                  <td><small class="text-muted"><%= new Date(u.created_at).toLocaleDateString() %></small></td>
                </tr>
                <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Recent Articles Table -->
        <div class="col-12">
          <div class="admin-table">
            <div class="admin-table-header">
              <h6><i class="fas fa-newspaper me-2"></i>Recent Articles</h6>
              <a href="/admin/articles" class="btn btn-sm btn-outline-primary">Manage All</a>
            </div>
            <div class="table-responsive">
              <table class="table mb-0">
                <thead><tr><th>Title</th><th>Author</th><th>Category</th><th>Status</th><th>Views</th><th>Date</th><th>Actions</th></tr></thead>
                <tbody>
                <% recentArticles.forEach(art => { %>
                <tr>
                  <td><div style="max-width:250px;font-size:13px;font-weight:500"><%= art.title.substring(0,55)+(art.title.length>55?'...':'') %></div></td>
                  <td><small><%= art.first_name %> <%= art.last_name %></small></td>
                  <td><small class="text-muted"><%= art.category_name||'—' %></small></td>
                  <td><span class="status-badge status-<%= art.status %>"><%= art.status %></span></td>
                  <td><small><i class="fas fa-eye me-1"></i><%= art.views||0 %></small></td>
                  <td><small class="text-muted"><%= new Date(art.created_at).toLocaleDateString() %></small></td>
                  <td>
                    <% if(art.status==='pending'){%><a href="/admin/articles/<%= art.id %>/review" class="btn btn-xs btn-warning text-white p-1" style="font-size:11px">Review</a><%}%>
                    <% if(art.status==='published'){%><a href="/article/<%= art.slug %>" target="_blank" class="btn btn-xs btn-outline-primary p-1" style="font-size:11px"><i class="fas fa-eye"></i></a><%}%>
                  </td>
                </tr>
                <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Announcements -->
        <div class="col-lg-6">
          <div class="admin-table">
            <div class="admin-table-header">
              <h6><i class="fas fa-bullhorn me-2"></i>Active Announcements</h6>
              <a href="/admin/announcements/create" class="btn btn-sm btn-primary"><i class="fas fa-plus me-1"></i>New</a>
            </div>
            <% if(announcements.length===0){%>
            <div class="empty-state p-3"><p class="mb-0 text-muted" style="font-size:13px">No announcements yet.</p></div>
            <%}else{%>
            <div class="p-3">
              <% announcements.forEach(ann => { %>
              <div class="d-flex justify-content-between align-items-start py-2 border-bottom">
                <div>
                  <span class="badge text-white me-2" style="background:<%= ann.priority==='urgent'?'var(--danger)':ann.priority==='high'?'var(--warning)':'var(--primary)' %>"><%= ann.priority %></span>
                  <span style="font-size:13px;font-weight:500"><%= ann.title.substring(0,40) %></span>
                  <div style="font-size:11px;color:var(--text-muted)"><%= new Date(ann.created_at).toLocaleDateString() %></div>
                </div>
                <form action="/admin/announcements/<%= ann.id %>/toggle" method="POST">
                  <button class="btn btn-xs btn-outline-secondary p-1" style="font-size:11px" title="Toggle"><i class="fas fa-toggle-on"></i></button>
                </form>
              </div>
              <% }) %>
            </div>
            <%}%>
          </div>
        </div>

        <!-- Quick Links -->
        <div class="col-lg-6">
          <div class="bg-white rounded-3 shadow-sm p-4">
            <h6 style="font-family:var(--font-display);font-weight:700;color:var(--primary)" class="mb-3"><i class="fas fa-bolt me-2"></i>Quick Actions</h6>
            <div class="row g-2">
              <% [
                {href:'/admin/articles?status=pending',icon:'fas fa-clock',label:'Review Pending',color:'warning'},
                {href:'/admin/articles',icon:'fas fa-newspaper',label:'All Articles',color:'primary'},
                {href:'/admin/users',icon:'fas fa-users',label:'Manage Users',color:'success'},
                {href:'/admin/announcements/create',icon:'fas fa-bullhorn',label:'New Announcement',color:'info'},
                {href:'/admin/categories',icon:'fas fa-tags',label:'Categories',color:'secondary'},
                {href:'/admin/analytics',icon:'fas fa-chart-bar',label:'Analytics',color:'danger'}
              ].forEach(link => { %>
              <div class="col-6">
                <a href="<%= link.href %>" class="d-flex align-items-center gap-2 p-3 rounded-3 text-decoration-none" style="background:var(--bg-light);color:var(--text-dark);transition:all 0.2s" onmouseover="this.style.background='var(--primary)';this.style.color='white'" onmouseout="this.style.background='var(--bg-light)';this.style.color='var(--text-dark)'">
                  <i class="<%= link.icon %>"></i>
                  <span style="font-size:13px;font-weight:500"><%= link.label %></span>
                </a>
              </div>
              <% }) %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/public/js/main.js"></script>
</body>
</html>
