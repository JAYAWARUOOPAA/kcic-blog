<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="/public/css/style.css" rel="stylesheet">
</head>
<body>
<div class="admin-layout">
  <%- include('../partials/admin-sidebar', { user, currentPage }) %>
  <div class="admin-main">
    <div class="admin-topbar">
      <div class="d-flex align-items-center gap-3">
        <button class="btn btn-sm btn-outline-secondary d-lg-none" id="sidebarToggleBtn"><i class="fas fa-bars"></i></button>
        <h5><i class="fas fa-clipboard-check me-2"></i>Review Article</h5>
      </div>
      <a href="/admin/articles" class="btn btn-sm btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Back to Articles</a>
    </div>
    <div class="admin-content">

      <div class="row g-4">
        <!-- Article Preview -->
        <div class="col-lg-8">
          <!-- Status Banner -->
          <% if(article.status==='pending'){ %>
          <div class="alert alert-warning mb-4">
            <i class="fas fa-clock me-2"></i><strong>Pending Review</strong> — This article is waiting for your decision. Review the content below and approve or reject it.
          </div>
          <% } else if(article.status==='published'){ %>
          <div class="alert alert-success mb-4">
            <i class="fas fa-check-circle me-2"></i><strong>Published</strong> — This article is live on the blog.
          </div>
          <% } else if(article.status==='rejected'){ %>
          <div class="alert alert-danger mb-4">
            <i class="fas fa-times-circle me-2"></i><strong>Rejected</strong> — Reason: <%= article.rejection_reason||'No reason provided' %>
          </div>
          <% } %>

          <!-- Article Content Preview -->
          <div class="review-section">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <div>
                <% if(article.category_name){ %><span class="article-category d-inline-block mb-2" style="background:<%= article.category_color||'var(--primary)' %>"><%= article.category_name %></span><% } %>
                <h2 style="font-family:var(--font-display);font-weight:800;color:var(--primary-dark)"><%= article.title %></h2>
              </div>
            </div>

            <div class="d-flex flex-wrap gap-3 mb-4 pb-3 border-bottom" style="font-size:13px;color:var(--text-muted)">
              <span><i class="fas fa-user me-1"></i><strong><%= article.first_name %> <%= article.last_name %></strong> (<%= article.username %>)</span>
              <span><i class="fas fa-envelope me-1"></i><%= article.email %></span>
              <% if(article.department){ %><span><i class="fas fa-university me-1"></i><%= article.department %></span><% } %>
              <span><i class="fas fa-calendar me-1"></i>Submitted <%= new Date(article.created_at).toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'}) %></span>
              <span><i class="fas fa-clock me-1"></i><%= article.reading_time %> min read</span>
            </div>

            <% if(article.excerpt){ %>
            <div class="p-3 rounded-3 mb-4" style="background:#f0f7ff;border-left:4px solid var(--primary)">
              <strong style="font-size:12px;text-transform:uppercase;color:var(--primary)">Excerpt:</strong>
              <p class="mb-0 mt-1"><%= article.excerpt %></p>
            </div>
            <% } %>

            <% if(article.tags && article.tags.length > 0){ %>
            <div class="mb-4">
              <strong style="font-size:12px;color:var(--text-muted)">TAGS:</strong>
              <% article.tags.forEach(t => { %><span class="tag-badge ms-1"><%= t %></span><% }) %>
            </div>
            <% } %>

            <div class="article-content">
              <%- article.content %>
            </div>
          </div>
        </div>

        <!-- Review Panel -->
        <div class="col-lg-4">
          <div style="position:sticky;top:80px">

            <!-- Author Info -->
            <div class="review-section mb-4">
              <h6 style="font-family:var(--font-display);font-weight:700;color:var(--primary)" class="mb-3"><i class="fas fa-user-circle me-2"></i>Author Info</h6>
              <div class="d-flex align-items-center gap-3 mb-3">
                <div style="width:50px;height:50px;border-radius:50%;background:var(--primary);color:white;display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:700;flex-shrink:0">
                  <%= (article.first_name||'U')[0] %>
                </div>
                <div>
                  <div class="fw-600"><%= article.first_name %> <%= article.last_name %></div>
                  <div class="text-muted" style="font-size:12px"><%= article.email %></div>
                  <% if(article.department){ %><div class="text-muted" style="font-size:12px"><i class="fas fa-university me-1"></i><%= article.department %></div><% } %>
                </div>
              </div>
            </div>

            <!-- Article Details -->
            <div class="review-section mb-4">
              <h6 style="font-family:var(--font-display);font-weight:700;color:var(--primary)" class="mb-3"><i class="fas fa-info-circle me-2"></i>Article Details</h6>
              <ul class="list-unstyled mb-0" style="font-size:13px">
                <li class="d-flex justify-content-between py-2 border-bottom">
                  <span class="text-muted">Status</span>
                  <span class="status-badge status-<%= article.status %>"><%= article.status %></span>
                </li>
                <li class="d-flex justify-content-between py-2 border-bottom">
                  <span class="text-muted">Category</span>
                  <span><%= article.category_name||'Uncategorized' %></span>
                </li>
                <li class="d-flex justify-content-between py-2 border-bottom">
                  <span class="text-muted">Reading Time</span>
                  <span><%= article.reading_time %> min</span>
                </li>
                <li class="d-flex justify-content-between py-2 border-bottom">
                  <span class="text-muted">Word Count</span>
                  <span>~<%= Math.ceil(article.content.split(' ').length) %></span>
                </li>
                <li class="d-flex justify-content-between py-2">
                  <span class="text-muted">Submitted</span>
                  <span><%= new Date(article.created_at).toLocaleDateString() %></span>
                </li>
              </ul>
            </div>

            <!-- Review Actions -->
            <% if(article.status === 'pending' || article.status === 'rejected'){ %>
            <div class="review-section">
              <h6 style="font-family:var(--font-display);font-weight:700;color:var(--primary)" class="mb-3"><i class="fas fa-gavel me-2"></i>Editorial Decision</h6>

              <!-- Approve -->
              <form action="/admin/articles/<%= article.id %>/approve" method="POST" class="mb-3">
                <button type="submit" class="btn btn-success w-100 py-3" style="font-size:16px;font-weight:700"
                  data-confirm="Approve and publish this article? It will become visible to all readers.">
                  <i class="fas fa-check-circle me-2"></i>APPROVE & PUBLISH
                </button>
              </form>

              <div class="divider-text text-center mb-3"><span class="text-muted" style="font-size:12px">— or —</span></div>

              <!-- Reject with reason -->
              <div id="rejectSection">
                <button type="button" class="btn btn-outline-danger w-100 mb-2" onclick="document.getElementById('rejectForm').classList.toggle('d-none')">
                  <i class="fas fa-times-circle me-2"></i>REJECT ARTICLE
                </button>
                <div id="rejectForm" class="d-none">
                  <form action="/admin/articles/<%= article.id %>/reject" method="POST">
                    <div class="mb-3">
                      <label class="form-label fw-600" style="font-size:13px">Rejection Reason <span class="text-danger">*</span></label>
                      <select name="rejection_reason" class="form-select form-select-sm mb-2" onchange="if(this.value!=='custom')document.getElementById('customReason').value=this.value">
                        <option value="">— Select a reason —</option>
                        <option value="Does not meet academic writing standards">Does not meet academic standards</option>
                        <option value="Content is not original or may be plagiarized">Possible plagiarism</option>
                        <option value="Insufficient depth or research">Insufficient research depth</option>
                        <option value="Missing citations or references">Missing citations</option>
                        <option value="Content is off-topic for this blog">Off-topic content</option>
                        <option value="Contains inappropriate or offensive content">Inappropriate content</option>
                        <option value="Article needs significant revisions">Needs major revisions</option>
                        <option value="custom">Other (specify below)</option>
                      </select>
                      <textarea id="customReason" name="rejection_reason" class="form-control form-control-sm" rows="3" placeholder="Enter specific feedback for the author..." required></textarea>
                      <div class="form-text"><i class="fas fa-info-circle me-1"></i>This message will be sent to the author.</div>
                    </div>
                    <button type="submit" class="btn btn-danger w-100" data-confirm="Reject this article? The author will be notified.">
                      <i class="fas fa-times me-2"></i>Confirm Rejection
                    </button>
                  </form>
                </div>
              </div>
            </div>
            <% } else if(article.status==='published'){ %>
            <div class="review-section">
              <h6 style="font-family:var(--font-display);font-weight:700;color:var(--primary)" class="mb-3"><i class="fas fa-tools me-2"></i>Actions</h6>
              <a href="/article/<%= article.slug %>" target="_blank" class="btn btn-primary w-100 mb-2"><i class="fas fa-external-link-alt me-2"></i>View Live Article</a>
              <form action="/admin/articles/<%= article.id %>/feature" method="POST" class="mb-2">
                <button class="btn btn-outline-warning w-100"><i class="fas fa-star me-2"></i><%= article.is_featured?'Remove from Featured':'Mark as Featured' %></button>
              </form>
              <form action="/admin/articles/<%= article.id %>/delete" method="POST">
                <button type="submit" class="btn btn-outline-danger w-100" data-confirm="Delete this published article?"><i class="fas fa-trash me-2"></i>Delete Article</button>
              </form>
            </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/public/js/main.js"></script>
<script>
// Sync rejection reason select with textarea
document.querySelector('select[name="rejection_reason"]')?.addEventListener('change', function(){
  if(this.value && this.value !== 'custom') {
    document.getElementById('customReason').value = this.value;
  } else if(this.value === 'custom') {
    document.getElementById('customReason').value = '';
    document.getElementById('customReason').focus();
  }
});
</script>
</body>
</html>
