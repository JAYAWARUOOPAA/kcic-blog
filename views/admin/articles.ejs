<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="/public/css/style.css" rel="stylesheet">
</head>
<body>
<div class="admin-layout">
  <%- include('../partials/admin-sidebar', { user, currentPage }) %>
  <div class="admin-main">
    <div class="admin-topbar">
      <div class="d-flex align-items-center gap-3">
        <button class="btn btn-sm btn-outline-secondary d-lg-none" id="sidebarToggleBtn"><i class="fas fa-bars"></i></button>
        <h5><i class="fas fa-newspaper me-2"></i>Manage Articles</h5>
      </div>
      <a href="/admin/dashboard" class="btn btn-sm btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Dashboard</a>
    </div>
    <div class="admin-content">

      <% if (success) { %><div class="alert alert-success alert-auto-dismiss mb-4"><i class="fas fa-check-circle me-2"></i><%= success %></div><% } %>

      <!-- Filters -->
      <div class="bg-white rounded-3 shadow-sm p-4 mb-4">
        <form action="/admin/articles" method="GET" class="row g-3 align-items-end">
          <div class="col-md-4">
            <label class="form-label fw-600" style="font-size:13px">Search</label>
            <input type="text" name="search" class="form-control" value="<%= search %>" placeholder="Search by title or author...">
          </div>
          <div class="col-md-3">
            <label class="form-label fw-600" style="font-size:13px">Status</label>
            <select name="status" class="form-select">
              <option value="all" <%=currentStatus==='all'?'selected':''%>>All Statuses</option>
              <option value="pending" <%=currentStatus==='pending'?'selected':''%>>⏳ Pending Review</option>
              <option value="published" <%=currentStatus==='published'?'selected':''%>>✅ Published</option>
              <option value="draft" <%=currentStatus==='draft'?'selected':''%>>📝 Draft</option>
              <option value="rejected" <%=currentStatus==='rejected'?'selected':''%>>❌ Rejected</option>
              <option value="archived" <%=currentStatus==='archived'?'selected':''%>>📦 Archived</option>
            </select>
          </div>
          <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100"><i class="fas fa-filter me-1"></i>Filter</button>
          </div>
          <div class="col-md-3">
            <div class="d-flex gap-2">
              <a href="/admin/articles?status=pending" class="btn btn-warning text-white btn-sm w-100">
                <i class="fas fa-clock me-1"></i>Pending (<%= pagination.total %>)
              </a>
            </div>
          </div>
        </form>
      </div>

      <!-- Status Tabs -->
      <div class="d-flex gap-2 flex-wrap mb-4">
        <% ['all','pending','published','draft','rejected','archived'].forEach(s => { %>
        <a href="/admin/articles?status=<%= s %>" class="btn btn-sm <%= currentStatus===s ? 'btn-primary' : 'btn-outline-secondary' %>">
          <%= s.charAt(0).toUpperCase()+s.slice(1) %>
          <% if(s==='pending' && currentStatus!=='pending'){ %><span class="badge bg-danger ms-1">!</span><% } %>
        </a>
        <% }) %>
      </div>

      <div class="admin-table">
        <div class="admin-table-header">
          <h6><i class="fas fa-list me-2"></i>Articles (<%= pagination.total %>)</h6>
          <small class="text-muted">Page <%= pagination.page %> of <%= pagination.totalPages %></small>
        </div>
        <% if(articles.length===0){ %>
        <div class="empty-state p-5 text-center">
          <i class="fas fa-newspaper d-block mb-3" style="font-size:48px;color:var(--border)"></i>
          <h6>No Articles Found</h6>
          <p class="text-muted">Try adjusting your filters.</p>
        </div>
        <% } else { %>
        <div class="table-responsive">
          <table class="table">
            <thead>
              <tr>
                <th style="width:35%">Article</th>
                <th>Author</th>
                <th>Category</th>
                <th>Status</th>
                <th>Views</th>
                <th>Date</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
            <% articles.forEach(art => { %>
            <tr class="<%= art.status==='pending'?'table-warning':'' %>">
              <td>
                <div class="fw-500" style="font-size:13px;max-width:280px">
                  <% if(art.is_featured){%><i class="fas fa-star text-warning me-1" title="Featured"></i><%}%>
                  <%= art.title.substring(0,65)+(art.title.length>65?'...':'') %>
                </div>
                <% if(art.status==='rejected' && art.rejection_reason){ %>
                <small class="text-danger d-block mt-1"><i class="fas fa-info-circle me-1"></i><%= art.rejection_reason.substring(0,60) %></small>
                <% } %>
              </td>
              <td>
                <div style="font-size:12px">
                  <div class="fw-500"><%= art.first_name %> <%= art.last_name %></div>
                  <div class="text-muted"><%= art.email %></div>
                </div>
              </td>
              <td><small class="text-muted"><%= art.category_name||'—' %></small></td>
              <td><span class="status-badge status-<%= art.status %>"><%= art.status %></span></td>
              <td><small><i class="fas fa-eye me-1 text-muted"></i><%= art.views||0 %></small></td>
              <td><small class="text-muted"><%= new Date(art.created_at).toLocaleDateString() %></small></td>
              <td>
                <div class="d-flex gap-1 flex-wrap">
                  <% if(art.status==='pending'){ %>
                  <a href="/admin/articles/<%= art.id %>/review" class="btn btn-sm btn-primary" title="Review Article">
                    <i class="fas fa-eye me-1"></i>Review
                  </a>
                  <% } %>
                  <% if(art.status==='published'){ %>
                  <a href="/article/<%= art.slug %>" target="_blank" class="btn btn-sm btn-outline-primary" title="View Live">
                    <i class="fas fa-external-link-alt"></i>
                  </a>
                  <form action="/admin/articles/<%= art.id %>/feature" method="POST" class="d-inline">
                    <button class="btn btn-sm <%= art.is_featured?'btn-warning':'btn-outline-warning' %>" title="<%= art.is_featured?'Unfeature':'Feature' %>">
                      <i class="fas fa-star"></i>
                    </button>
                  </form>
                  <% } %>
                  <form action="/admin/articles/<%= art.id %>/delete" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-sm btn-outline-danger" data-confirm="Permanently delete this article?" title="Delete">
                      <i class="fas fa-trash"></i>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <% if(pagination.totalPages > 1){ %>
        <div class="p-3 border-top d-flex justify-content-between align-items-center">
          <small class="text-muted">Showing <%= (pagination.page-1)*15+1 %>–<%= Math.min(pagination.page*15, pagination.total) %> of <%= pagination.total %></small>
          <nav><ul class="pagination pagination-sm mb-0">
            <li class="page-item <%=pagination.page===1?'disabled':''%>"><a class="page-link" href="?page=<%=pagination.page-1%>&status=<%=currentStatus%>&search=<%=search%>"><i class="fas fa-chevron-left"></i></a></li>
            <% for(let i=1;i<=pagination.totalPages;i++){if(Math.abs(i-pagination.page)<=2||i===1||i===pagination.totalPages){ %>
            <li class="page-item <%=pagination.page===i?'active':''%>"><a class="page-link" href="?page=<%=i%>&status=<%=currentStatus%>&search=<%=search%>"><%=i%></a></li>
            <%}else if(Math.abs(i-pagination.page)===3){%><li class="page-item disabled"><span class="page-link">...</span></li><%}}%>
            <li class="page-item <%=pagination.page===pagination.totalPages?'disabled':''%>"><a class="page-link" href="?page=<%=pagination.page+1%>&status=<%=currentStatus%>&search=<%=search%>"><i class="fas fa-chevron-right"></i></a></li>
          </ul></nav>
        </div>
        <% } %>
        <% } %>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/public/js/main.js"></script>
</body>
</html>
