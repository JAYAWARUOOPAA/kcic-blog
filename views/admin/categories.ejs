<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="/public/css/style.css" rel="stylesheet">
</head>
<body>
<div class="admin-layout">
  <%- include('../partials/admin-sidebar', { user, currentPage }) %>
  <div class="admin-main">
    <div class="admin-topbar">
      <div class="d-flex align-items-center gap-3">
        <button class="btn btn-sm btn-outline-secondary d-lg-none" id="sidebarToggleBtn"><i class="fas fa-bars"></i></button>
        <h5><i class="fas fa-tags me-2"></i>Manage Categories</h5>
      </div>
      <a href="/admin/dashboard" class="btn btn-sm btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Dashboard</a>
    </div>
    <div class="admin-content">
      <% if(success){%><div class="alert alert-success alert-auto-dismiss mb-4"><i class="fas fa-check-circle me-2"></i><%= success %></div><%}%>
      <% if(error){%><div class="alert alert-danger alert-auto-dismiss mb-4"><i class="fas fa-exclamation-circle me-2"></i><%= error %></div><%}%>

      <div class="row g-4">
        <!-- Create Category Form -->
        <div class="col-lg-4">
          <div class="bg-white rounded-3 shadow-sm p-4">
            <h6 style="font-family:var(--font-display);font-weight:700;color:var(--primary)" class="mb-4"><i class="fas fa-plus-circle me-2"></i>Add New Category</h6>
            <form action="/admin/categories/create" method="POST">
              <div class="mb-3">
                <label class="form-label fw-600">Category Name <span class="text-danger">*</span></label>
                <input type="text" name="name" class="form-control" placeholder="e.g. Computer Science" required maxlength="100">
              </div>
              <div class="mb-3">
                <label class="form-label fw-600">Description</label>
                <textarea name="description" class="form-control" rows="3" placeholder="Brief description of this category..."></textarea>
              </div>
              <div class="row g-2 mb-3">
                <div class="col-6">
                  <label class="form-label fw-600">Color</label>
                  <input type="color" name="color" class="form-control form-control-color w-100" value="#1a3c5e" title="Choose category color">
                </div>
                <div class="col-6">
                  <label class="form-label fw-600">Icon Class</label>
                  <input type="text" name="icon" class="form-control" value="fas fa-folder" placeholder="fas fa-folder">
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label fw-600" style="font-size:12px">Quick Icon Picker</label>
                <div class="d-flex flex-wrap gap-2">
                  <% ['fas fa-microscope','fas fa-flask','fas fa-palette','fas fa-chart-line','fas fa-heartbeat','fas fa-balance-scale','fas fa-users','fas fa-graduation-cap','fas fa-code','fas fa-globe','fas fa-book','fas fa-brain'].forEach(icon => { %>
                  <button type="button" class="btn btn-outline-secondary btn-sm p-1 px-2" onclick="document.querySelector('input[name=icon]').value='<%= icon %>'" title="<%= icon %>">
                    <i class="<%= icon %>"></i>
                  </button>
                  <% }) %>
                </div>
              </div>
              <button type="submit" class="btn btn-primary w-100"><i class="fas fa-plus me-2"></i>Create Category</button>
            </form>
          </div>
        </div>

        <!-- Categories List -->
        <div class="col-lg-8">
          <div class="admin-table">
            <div class="admin-table-header">
              <h6><i class="fas fa-list me-2"></i>All Categories (<%= categories.length %>)</h6>
            </div>
            <% if(categories.length===0){ %>
            <div class="empty-state p-4 text-center"><p>No categories yet.</p></div>
            <% } else { %>
            <div class="table-responsive">
              <table class="table">
                <thead><tr><th>Category</th><th>Description</th><th>Articles</th><th>Actions</th></tr></thead>
                <tbody>
                <% categories.forEach(cat => { %>
                <tr>
                  <td>
                    <div class="d-flex align-items-center gap-3">
                      <div style="width:40px;height:40px;border-radius:8px;background:<%= cat.color||'var(--primary)' %>;display:flex;align-items:center;justify-content:center;color:white;font-size:18px;flex-shrink:0">
                        <i class="<%= cat.icon||'fas fa-folder' %>"></i>
                      </div>
                      <div>
                        <div class="fw-600" style="font-size:14px"><%= cat.name %></div>
                        <div class="text-muted" style="font-size:11px">/<%= cat.slug %></div>
                      </div>
                    </div>
                  </td>
                  <td><small class="text-muted"><%= cat.description ? cat.description.substring(0,60)+'...' : '—' %></small></td>
                  <td>
                    <a href="/admin/articles?category=<%= cat.slug %>" class="badge bg-light text-dark border text-decoration-none">
                      <i class="fas fa-file-alt me-1"></i><%= cat.article_count||0 %> articles
                    </a>
                  </td>
                  <td>
                    <div class="d-flex gap-1">
                      <a href="/articles?category=<%= cat.slug %>" class="btn btn-sm btn-outline-primary" target="_blank" title="View Articles"><i class="fas fa-eye"></i></a>
                      <form action="/admin/categories/<%= cat.id %>/delete" method="POST" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger" data-confirm="Delete '<%= cat.name %>'? Articles will be uncategorized." title="Delete">
                          <i class="fas fa-trash"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                </tbody>
              </table>
            </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/public/js/main.js"></script>
</body>
</html>
