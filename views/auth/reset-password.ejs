<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="/public/css/style.css" rel="stylesheet">
</head>
<body>
<div class="auth-wrapper">
  <div class="w-100 px-3">
    <div class="auth-card mx-auto">
      <div class="auth-header">
        <div class="mb-3" style="font-size:48px;"><i class="fas fa-lock-open"></i></div>
        <h2>Reset Password</h2>
        <p>Create a new secure password</p>
      </div>
      <div class="auth-body">
        <% if (error) { %><div class="alert alert-danger"><i class="fas fa-exclamation-circle me-2"></i><%= error %></div><% } %>
        <form action="/auth/reset-password/<%= token %>" method="POST">
          <div class="mb-3">
            <label class="form-label"><i class="fas fa-lock me-1"></i>New Password</label>
            <div class="position-relative">
              <input type="password" name="password" id="pwd1" class="form-control pe-5" placeholder="Min. 8 characters" minlength="8" required>
              <button type="button" class="search-btn" style="position:absolute;right:12px;top:50%;transform:translateY(-50%)" onclick="togglePwd('pwd1','i1')"><i class="fas fa-eye" id="i1"></i></button>
            </div>
          </div>
          <div class="mb-4">
            <label class="form-label"><i class="fas fa-lock me-1"></i>Confirm New Password</label>
            <div class="position-relative">
              <input type="password" name="confirm_password" id="pwd2" class="form-control pe-5" placeholder="Repeat password" minlength="8" required>
              <button type="button" class="search-btn" style="position:absolute;right:12px;top:50%;transform:translateY(-50%)" onclick="togglePwd('pwd2','i2')"><i class="fas fa-eye" id="i2"></i></button>
            </div>
          </div>
          <button type="submit" class="btn btn-primary w-100 py-2"><i class="fas fa-save me-2"></i>Reset Password</button>
        </form>
        <div class="text-center mt-4 pt-3 border-top">
          <a href="/auth/login" class="text-primary" style="font-size:14px;text-decoration:none"><i class="fas fa-arrow-left me-1"></i>Back to Login</a>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
function togglePwd(id, iconId) {
  const f = document.getElementById(id), i = document.getElementById(iconId);
  if (f.type === 'password') { f.type = 'text'; i.className = 'fas fa-eye-slash'; }
  else { f.type = 'password'; i.className = 'fas fa-eye'; }
}
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
