<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="/public/css/style.css" rel="stylesheet">
</head>
<body>
<div class="auth-wrapper" style="padding: 30px 0;">
  <div class="w-100 px-3">
    <div class="auth-card mx-auto" style="max-width:520px;">
      <div class="auth-header">
        <div class="brand-logo justify-content-center mb-3">
          <div class="brand-icon-lg"><i class="fas fa-graduation-cap"></i></div>
          <div class="brand-text-lg ms-2">
            <span class="brand-name-lg">KCIC</span>
            <span class="brand-sub-lg d-block">Academic Blog</span>
          </div>
        </div>
        <h2>Create Account</h2>
        <p>Join the KCIC academic community</p>
      </div>
      <div class="auth-body">
        <% if (error) { %><div class="alert alert-danger"><i class="fas fa-exclamation-circle me-2"></i><%= error %></div><% } %>

        <!-- Role Selection -->
        <div class="mb-4">
          <label class="form-label fw-600">Register as</label>
          <div class="d-flex gap-3">
            <div class="role-option active" onclick="selectRole('user', this)" style="flex:1;padding:12px;border:2px solid var(--primary);border-radius:8px;cursor:pointer;text-align:center;background:var(--primary);color:white;transition:all 0.2s;">
              <i class="fas fa-user-graduate d-block mb-1" style="font-size:20px;"></i>
              <strong style="font-size:13px;">Student / User</strong>
            </div>
            <div class="role-option" onclick="selectRole('admin', this)" style="flex:1;padding:12px;border:2px solid var(--border);border-radius:8px;cursor:pointer;text-align:center;background:white;color:var(--text-dark);transition:all 0.2s;">
              <i class="fas fa-shield-alt d-block mb-1" style="font-size:20px;"></i>
              <strong style="font-size:13px;">Administrator</strong>
            </div>
          </div>
        </div>

        <form action="/auth/register" method="POST">
          <input type="hidden" name="role" id="selectedRole" value="user">
          <div class="row g-3">
            <div class="col-6">
              <label class="form-label">First Name <span class="text-danger">*</span></label>
              <input type="text" name="first_name" class="form-control" placeholder="John" required>
            </div>
            <div class="col-6">
              <label class="form-label">Last Name <span class="text-danger">*</span></label>
              <input type="text" name="last_name" class="form-control" placeholder="Doe" required>
            </div>
            <div class="col-12">
              <label class="form-label"><i class="fas fa-at me-1"></i>Username <span class="text-danger">*</span></label>
              <input type="text" name="username" class="form-control" placeholder="johndoe" pattern="[a-zA-Z0-9_]{3,50}" title="3-50 chars, letters, numbers, underscores" required>
            </div>
            <div class="col-12">
              <label class="form-label"><i class="fas fa-envelope me-1"></i>Email Address <span class="text-danger">*</span></label>
              <input type="email" name="email" class="form-control" placeholder="john@kcic.edu" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Department</label>
              <select name="department" class="form-select">
                <option value="">Select Department</option>
                <option>Computer Science</option>
                <option>Business Administration</option>
                <option>Engineering</option>
                <option>Arts & Humanities</option>
                <option>Natural Sciences</option>
                <option>Social Sciences</option>
                <option>Law</option>
                <option>Medicine & Health</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Student ID</label>
              <input type="text" name="student_id" class="form-control" placeholder="KCIC2024001">
            </div>
            <div class="col-12">
              <label class="form-label"><i class="fas fa-lock me-1"></i>Password <span class="text-danger">*</span></label>
              <div class="position-relative">
                <input type="password" name="password" id="pwd1" class="form-control pe-5" placeholder="Min. 8 characters" minlength="8" required>
                <button type="button" class="search-btn" style="position:absolute;right:12px;top:50%;transform:translateY(-50%)" onclick="togglePwd('pwd1','icon1')">
                  <i class="fas fa-eye" id="icon1"></i>
                </button>
              </div>
            </div>
            <div class="col-12">
              <label class="form-label"><i class="fas fa-lock me-1"></i>Confirm Password <span class="text-danger">*</span></label>
              <div class="position-relative">
                <input type="password" name="confirm_password" id="pwd2" class="form-control pe-5" placeholder="Repeat password" minlength="8" required>
                <button type="button" class="search-btn" style="position:absolute;right:12px;top:50%;transform:translateY(-50%)" onclick="togglePwd('pwd2','icon2')">
                  <i class="fas fa-eye" id="icon2"></i>
                </button>
              </div>
            </div>
            <div class="col-12">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="terms" required>
                <label class="form-check-label" style="font-size:13px">
                  I agree to the <a href="#" class="text-primary">Terms of Service</a> and <a href="#" class="text-primary">Privacy Policy</a>
                </label>
              </div>
            </div>
            <div class="col-12">
              <button type="submit" class="btn btn-primary w-100 py-2">
                <i class="fas fa-user-plus me-2"></i>Create Account
              </button>
            </div>
          </div>
        </form>

        <div class="text-center mt-4 pt-3 border-top">
          <p class="mb-0" style="font-size:14px">Already have an account? <a href="/auth/login" class="text-primary fw-600">Sign In</a></p>
          <a href="/" class="d-block mt-2 text-muted" style="font-size:13px"><i class="fas fa-home me-1"></i>Back to Home</a>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
function selectRole(role, el) {
  document.getElementById('selectedRole').value = role;
  document.querySelectorAll('.role-option').forEach(o => {
    o.style.background = 'white'; o.style.color = 'var(--text-dark)'; o.style.borderColor = 'var(--border)';
  });
  el.style.background = 'var(--primary)'; el.style.color = 'white'; el.style.borderColor = 'var(--primary)';
}
function togglePwd(id, iconId) {
  const f = document.getElementById(id), i = document.getElementById(iconId);
  if (f.type === 'password') { f.type = 'text'; i.className = 'fas fa-eye-slash'; }
  else { f.type = 'password'; i.className = 'fas fa-eye'; }
}
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
