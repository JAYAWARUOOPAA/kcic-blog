<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="/public/css/style.css" rel="stylesheet">
</head>
<body>
<div class="auth-wrapper">
  <div class="w-100 px-3">
    <div class="auth-card mx-auto">
      <div class="auth-header">
        <div class="brand-logo justify-content-center mb-3">
          <div class="brand-icon-lg"><i class="fas fa-graduation-cap"></i></div>
          <div class="brand-text-lg ms-2">
            <span class="brand-name-lg">KCIC</span>
            <span class="brand-sub-lg d-block">Academic Blog</span>
          </div>
        </div>
        <h2>Welcome Back</h2>
        <p>Sign in to your account to continue</p>
      </div>
      <div class="auth-body">
        <% if (error) { %><div class="alert alert-danger alert-auto-dismiss"><i class="fas fa-exclamation-circle me-2"></i><%= error %></div><% } %>
        <% if (success) { %><div class="alert alert-success alert-auto-dismiss"><i class="fas fa-check-circle me-2"></i><%= success %></div><% } %>

        <!-- Role Selection -->
        <div class="mb-4">
          <label class="form-label">Login as</label>
          <div class="d-flex gap-3" id="roleSelector">
            <div class="role-option active" data-role="user" onclick="selectRole('user', this)" style="flex:1; padding:12px; border:2px solid var(--primary); border-radius:8px; cursor:pointer; text-align:center; background:var(--primary); color:white; transition:all 0.2s;">
              <i class="fas fa-user-graduate d-block mb-1" style="font-size:20px;"></i>
              <strong style="font-size:13px;">Student / User</strong>
            </div>
            <div class="role-option" data-role="admin" onclick="selectRole('admin', this)" style="flex:1; padding:12px; border:2px solid var(--border); border-radius:8px; cursor:pointer; text-align:center; background:white; color:var(--text-dark); transition:all 0.2s;">
              <i class="fas fa-shield-alt d-block mb-1" style="font-size:20px;"></i>
              <strong style="font-size:13px;">Administrator</strong>
            </div>
          </div>
        </div>

        <form action="/auth/login" method="POST" id="loginForm">
          <input type="hidden" name="role" id="selectedRole" value="user">
          <div class="mb-3">
            <label class="form-label"><i class="fas fa-envelope me-1"></i>Email Address</label>
            <input type="email" name="email" class="form-control" placeholder="your@email.com" required>
          </div>
          <div class="mb-3">
            <label class="form-label"><i class="fas fa-lock me-1"></i>Password</label>
            <div class="position-relative">
              <input type="password" name="password" id="passwordField" class="form-control pe-5" placeholder="••••••••" required>
              <button type="button" class="search-btn" style="position:absolute;right:12px;top:50%;transform:translateY(-50%)" onclick="togglePwd()">
                <i class="fas fa-eye" id="pwdIcon"></i>
              </button>
            </div>
          </div>
          <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="remember">
              <label class="form-check-label" style="font-size:13px">Remember me</label>
            </div>
            <a href="/auth/forgot-password" class="text-primary" style="font-size:13px;text-decoration:none;">Forgot password?</a>
          </div>
          <button type="submit" class="btn btn-primary w-100 py-2">
            <i class="fas fa-sign-in-alt me-2"></i>Sign In
          </button>
        </form>

        <div class="text-center mt-4 pt-3 border-top">
          <p class="mb-0" style="font-size:14px">Don't have an account? <a href="/auth/register" class="text-primary fw-600">Create Account</a></p>
          <a href="/" class="d-block mt-2 text-muted" style="font-size:13px"><i class="fas fa-home me-1"></i>Back to Home</a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function selectRole(role, el) {
  document.getElementById('selectedRole').value = role;
  document.querySelectorAll('.role-option').forEach(o => {
    o.style.background = 'white';
    o.style.color = 'var(--text-dark)';
    o.style.borderColor = 'var(--border)';
  });
  el.style.background = 'var(--primary)';
  el.style.color = 'white';
  el.style.borderColor = 'var(--primary)';
}
function togglePwd() {
  const f = document.getElementById('passwordField');
  const i = document.getElementById('pwdIcon');
  if (f.type === 'password') { f.type = 'text'; i.className = 'fas fa-eye-slash'; }
  else { f.type = 'password'; i.className = 'fas fa-eye'; }
}
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/public/js/main.js"></script>
</body>
</html>
