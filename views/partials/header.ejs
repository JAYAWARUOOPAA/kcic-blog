<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;800&family=Source+Sans+3:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link href="/public/css/style.css" rel="stylesheet">
  <%- typeof extraCSS !== 'undefined' ? extraCSS : '' %>
</head>
<body>

<!-- Top Bar -->
<div class="topbar">
  <div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center">
      <div class="topbar-left">
        <span><i class="fas fa-university me-1"></i> Kings Cornerstone International College</span>
        <span class="ms-3 d-none d-md-inline"><i class="fas fa-calendar me-1"></i> <%= new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span>
      </div>
      <div class="topbar-right">
        <% if (user) { %>
          <a href="/api/notifications/count" class="me-3 notification-bell" id="notifBell">
            <i class="fas fa-bell"></i> <span class="badge bg-danger notif-count" id="notifCount" style="display:none">0</span>
          </a>
          <% if (user.role === 'admin') { %>
            <a href="/admin/dashboard" class="me-2"><i class="fas fa-cog me-1"></i>Admin Panel</a>
          <% } %>
          <a href="/auth/logout"><i class="fas fa-sign-out-alt me-1"></i>Logout</a>
        <% } else { %>
          <a href="/auth/login" class="me-2"><i class="fas fa-sign-in-alt me-1"></i>Login</a>
          <a href="/auth/register"><i class="fas fa-user-plus me-1"></i>Register</a>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Main Navbar -->
<nav class="navbar navbar-expand-lg main-navbar sticky-top">
  <div class="container-fluid px-4">
    <a class="navbar-brand" href="/">
      <div class="brand-logo">
        <div class="brand-icon"><i class="fas fa-graduation-cap"></i></div>
        <div class="brand-text">
          <span class="brand-name">KCIC</span>
          <span class="brand-sub">Academic Blog</span>
        </div>
      </div>
    </a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarMain">
      <ul class="navbar-nav mx-auto">
        <li class="nav-item">
          <a class="nav-link <%= typeof currentPage !== 'undefined' && currentPage === 'home' ? 'active' : '' %>" href="/">
            <i class="fas fa-home me-1"></i>Home
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= typeof currentPage !== 'undefined' && currentPage === 'articles' ? 'active' : '' %>" href="/articles">
            <i class="fas fa-newspaper me-1"></i>Articles
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= typeof currentPage !== 'undefined' && currentPage === 'categories' ? 'active' : '' %>" href="/categories">
            <i class="fas fa-tags me-1"></i>Categories
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= typeof currentPage !== 'undefined' && currentPage === 'announcements' ? 'active' : '' %>" href="/announcements">
            <i class="fas fa-bullhorn me-1"></i>Announcements
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= typeof currentPage !== 'undefined' && currentPage === 'about' ? 'active' : '' %>" href="/about">
            <i class="fas fa-info-circle me-1"></i>About
          </a>
        </li>
      </ul>

      <!-- Search Form -->
      <div class="nav-search position-relative">
        <form action="/search" method="GET" class="d-flex">
          <div class="search-wrapper">
            <input type="text" name="q" class="form-control search-input" placeholder="Search articles..." autocomplete="off" id="navSearch">
            <button type="submit" class="search-btn"><i class="fas fa-search"></i></button>
          </div>
        </form>
        <div class="search-suggestions" id="searchSuggestions"></div>
      </div>

      <% if (user) { %>
      <div class="nav-user ms-3">
        <div class="dropdown">
          <button class="btn user-menu-btn dropdown-toggle" data-bs-toggle="dropdown">
            <% if (user.avatar_url) { %>
              <img src="<%= user.avatar_url %>" class="user-avatar-sm" alt="<%= user.username %>">
            <% } else { %>
              <div class="user-initials-sm"><%= (user.first_name || user.username)[0].toUpperCase() %></div>
            <% } %>
            <span class="ms-1 d-none d-lg-inline"><%= user.first_name || user.username %></span>
          </button>
          <ul class="dropdown-menu dropdown-menu-end user-dropdown">
            <li class="dropdown-header">
              <strong><%= user.first_name %> <%= user.last_name %></strong><br>
              <small class="text-muted"><%= user.email %></small>
              <span class="badge bg-<%= user.role === 'admin' ? 'danger' : 'primary' %> ms-1"><%= user.role %></span>
            </li>
            <li><hr class="dropdown-divider"></li>
            <% if (user.role === 'admin') { %>
              <li><a class="dropdown-item" href="/admin/dashboard"><i class="fas fa-tachometer-alt me-2"></i>Admin Dashboard</a></li>
              <li><a class="dropdown-item" href="/admin/articles"><i class="fas fa-file-alt me-2"></i>Manage Articles</a></li>
              <li><a class="dropdown-item" href="/admin/users"><i class="fas fa-users me-2"></i>Manage Users</a></li>
              <li><a class="dropdown-item" href="/admin/analytics"><i class="fas fa-chart-bar me-2"></i>Analytics</a></li>
            <% } else { %>
              <li><a class="dropdown-item" href="/user/dashboard"><i class="fas fa-tachometer-alt me-2"></i>Dashboard</a></li>
              <li><a class="dropdown-item" href="/user/create-article"><i class="fas fa-plus me-2"></i>Write Article</a></li>
              <li><a class="dropdown-item" href="/user/my-articles"><i class="fas fa-file-alt me-2"></i>My Articles</a></li>
              <li><a class="dropdown-item" href="/user/saved"><i class="fas fa-bookmark me-2"></i>Saved Articles</a></li>
              <li><a class="dropdown-item" href="/user/history"><i class="fas fa-history me-2"></i>Reading History</a></li>
              <li><a class="dropdown-item" href="/user/profile"><i class="fas fa-user-edit me-2"></i>Profile</a></li>
            <% } %>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item text-danger" href="/auth/logout"><i class="fas fa-sign-out-alt me-2"></i>Logout</a></li>
          </ul>
        </div>
      </div>
      <% } else { %>
      <div class="nav-auth ms-3">
        <a href="/auth/login" class="btn btn-outline-primary btn-sm me-2">Login</a>
        <a href="/auth/register" class="btn btn-primary btn-sm">Register</a>
      </div>
      <% } %>
    </div>
  </div>
</nav>
