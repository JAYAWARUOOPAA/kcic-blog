<%- include('../partials/header', { title: '403 - Access Denied', user: user||null, currentPage:'' }) %>
<div style="min-height:70vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:40px">
  <div>
    <i class="fas fa-ban fa-4x mb-4" style="color:var(--danger)"></i>
    <h2 style="font-family:var(--font-display);color:var(--primary-dark)">Access Denied</h2>
    <p class="text-muted mb-4">You don't have permission to access this page.</p>
    <a href="/" class="btn btn-primary px-5 me-2"><i class="fas fa-home me-2"></i>Go Home</a>
    <% if (!user) { %><a href="/auth/login" class="btn btn-outline-primary px-5"><i class="fas fa-sign-in-alt me-2"></i>Login</a><% } %>
  </div>
</div>
<%- include('../partials/footer') %>
