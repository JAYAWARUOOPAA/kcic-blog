<%- include('../partials/header', { title, user, currentPage }) %>
<div class="page-header">
  <div class="container">
    <h1><i class="fas fa-search me-2"></i>Search Results</h1>
    <p><% if(query) { %>Results for "<strong><%= query %></strong>"<% } else { %>Enter a search term to find articles<% } %></p>
  </div>
</div>
<div class="breadcrumb-section"><div class="container"><nav><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/"><i class="fas fa-home me-1"></i>Home</a></li><li class="breadcrumb-item active">Search</li></ol></nav></div></div>

<div class="container py-5">
  <!-- Search Bar -->
  <form action="/search" method="GET" class="mb-5">
    <div class="input-group input-group-lg" style="max-width:600px;margin:0 auto">
      <input type="text" name="q" class="form-control" value="<%= query %>" placeholder="Search articles, topics, authors...">
      <button class="btn btn-primary" type="submit"><i class="fas fa-search me-1"></i>Search</button>
    </div>
  </form>

  <% if (query) { %>
  <p class="text-muted mb-4"><strong><%= pagination.total %></strong> result<%= pagination.total!=1?'s':'' %> found for "<%= query %>"</p>
  <% } %>

  <% if (articles.length === 0 && query) { %>
  <div class="empty-state bg-white rounded-3 p-5 text-center">
    <i class="fas fa-search d-block mb-3" style="font-size:56px;color:var(--border)"></i>
    <h5>No Results Found</h5>
    <p>No articles match "<strong><%= query %></strong>". Try different keywords.</p>
    <div class="mt-3">
      <a href="/articles" class="btn btn-primary me-2">Browse All Articles</a>
      <a href="/categories" class="btn btn-outline-primary">View Categories</a>
    </div>
  </div>
  <% } else if (articles.length > 0) { %>
  <div class="row g-4">
    <% articles.forEach(art => { %>
    <div class="col-lg-4 col-md-6">
      <div class="article-card h-100">
        <div class="article-card-img" style="background:linear-gradient(135deg,<%= art.category_color||'var(--primary)' %>,var(--primary-dark))">
          <div class="article-card-img-placeholder"><i class="fas fa-file-alt"></i></div>
        </div>
        <div class="article-card-body">
          <% if (art.category_name) { %><a href="/articles?category=<%= art.category_slug %>" class="article-category" style="background:<%= art.category_color||'var(--primary)' %>"><%= art.category_name %></a><% } %>
          <h3 class="article-card-title"><a href="/article/<%= art.slug %>"><%= art.title %></a></h3>
          <p class="article-card-excerpt"><%= (art.excerpt||art.content.replace(/<[^>]+>/g,'')).substring(0,120)+'...' %></p>
          <div class="article-card-meta">
            <div class="article-meta-author"><i class="fas fa-user-circle"></i><%= art.first_name %> <%= art.last_name %></div>
            <div class="article-meta-stats">
              <span><i class="fas fa-eye"></i><%= art.views %></span>
              <span class="reading-time"><i class="fas fa-clock"></i><%= art.reading_time %>m</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    <% }) %>
  </div>

  <% if (pagination.totalPages > 1) { %>
  <nav class="mt-5 d-flex justify-content-center">
    <ul class="pagination">
      <li class="page-item <%= pagination.page===1?'disabled':'' %>">
        <a class="page-link" href="/search?q=<%= query %>&page=<%= pagination.page-1 %>"><i class="fas fa-chevron-left"></i></a>
      </li>
      <% for(let i=1;i<=pagination.totalPages;i++){if(Math.abs(i-pagination.page)<=2||i===1||i===pagination.totalPages){ %>
      <li class="page-item <%= pagination.page===i?'active':'' %>"><a class="page-link" href="/search?q=<%= query %>&page=<%= i %>"><%= i %></a></li>
      <% } else if(Math.abs(i-pagination.page)===3){ %><li class="page-item disabled"><span class="page-link">...</span></li><% } } %>
      <li class="page-item <%= pagination.page===pagination.totalPages?'disabled':'' %>">
        <a class="page-link" href="/search?q=<%= query %>&page=<%= pagination.page+1 %>"><i class="fas fa-chevron-right"></i></a>
      </li>
    </ul>
  </nav>
  <% } %>
  <% } %>
</div>
<%- include('../partials/footer') %>
