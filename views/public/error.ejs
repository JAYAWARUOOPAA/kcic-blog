<%- include('../partials/header', { title: 'Error', user: user||null, currentPage:'' }) %>
<div style="min-height:70vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:40px">
  <div>
    <i class="fas fa-exclamation-triangle fa-4x mb-4" style="color:var(--danger)"></i>
    <h2 style="font-family:var(--font-display);color:var(--primary-dark)">Something Went Wrong</h2>
    <p class="text-muted mb-4"><%= typeof error !== 'undefined' ? error : 'An unexpected error occurred.' %></p>
    <a href="/" class="btn btn-primary px-5"><i class="fas fa-home me-2"></i>Go Home</a>
  </div>
</div>
<%- include('../partials/footer') %>
