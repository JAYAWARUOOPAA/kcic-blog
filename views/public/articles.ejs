<%- include('../partials/header', { title, user, currentPage }) %>

<div class="page-header">
  <div class="container">
    <h1><i class="fas fa-newspaper me-2"></i>Articles</h1>
    <p>Explore academic research and scholarly articles from KCIC students and faculty</p>
  </div>
</div>

<div class="breadcrumb-section">
  <div class="container">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/"><i class="fas fa-home me-1"></i>Home</a></li>
        <li class="breadcrumb-item active">Articles</li>
      </ol>
    </nav>
  </div>
</div>

<div class="container py-5">
  <div class="row g-4">

```
<!-- Main Content -->
<div class="col-lg-9">

  <!-- Filters -->
  <div class="bg-white rounded-3 p-3 mb-4 shadow-sm d-flex flex-wrap gap-3 align-items-center justify-content-between">
    <div class="d-flex gap-2 flex-wrap">
      <a href="/articles" class="btn btn-sm <%= !currentCategory ? 'btn-primary' : 'btn-outline-secondary' %>">All</a>

      <% if (Array.isArray(categories)) { categories.forEach(cat => { %>
        <a href="/articles?category=<%= cat.slug %>" 
           class="btn btn-sm <%= currentCategory === cat.slug ? 'btn-primary' : 'btn-outline-secondary' %>"
           style="<%= currentCategory === cat.slug ? 'background:'+cat.color+';border-color:'+cat.color : '' %>">
          <i class="<%= cat.icon %> me-1"></i><%= cat.name %>
        </a>
      <% }) } %>
    </div>

    <div class="d-flex align-items-center gap-2">
      <label class="form-label mb-0 text-muted" style="font-size:13px">Sort:</label>
      <select class="form-select form-select-sm" style="width:auto"
        onchange="location.href='/articles?sort='+this.value+'<%= currentCategory ? '&category='+currentCategory : '' %>'">
        <option value="latest" <%= currentSort==='latest'?'selected':'' %>>Latest</option>
        <option value="popular" <%= currentSort==='popular'?'selected':'' %>>Most Views</option>
        <option value="liked" <%= currentSort==='liked'?'selected':'' %>>Most Liked</option>
      </select>
    </div>
  </div>

  <!-- Count -->
  <p class="text-muted mb-3" style="font-size:14px">
    Showing <%= ((pagination.page-1)*pagination.limit)+1 %>–<%= Math.min(pagination.page*pagination.limit, pagination.totalArticles) %> of <%= pagination.totalArticles %> articles
  </p>

  <% if (articles.length === 0) { %>

    <div class="bg-white rounded-3 p-5 text-center">
      <h5>No Articles Found</h5>
      <p>Try again later</p>
    </div>

  <% } else { %>

  <div class="row g-4">

    <% articles.forEach(art => { %>

    <div class="col-md-6">
      <div class="article-card h-100">

        <!-- ✅ IMAGE FIX APPLIED HERE -->
        <div class="article-card-img">
          <% if (art.cover_image) { %>
            <img 
              src="/public/images/<%= art.cover_image %>" 
              alt="<%= art.title %>"
              style="width:100%; height:200px; object-fit:cover;"
            >
          <% } else { %>
            <div style="height:200px; background:#eee; display:flex; align-items:center; justify-content:center;">
              No Image
            </div>
          <% } %>
        </div>

        <div class="article-card-body">

          <% if (art.category_name) { %>
            <span class="badge mb-2" style="background:<%= art.category_color || '#007bff' %>">
              <%= art.category_name %>
            </span>
          <% } %>

          <h3>
            <a href="/article/<%= art.slug %>">
              <%= art.title %>
            </a>
          </h3>

          <p>
            <%= (art.excerpt || art.content.replace(/<[^>]+>/g,'')).substring(0,120) %>...
          </p>

          <div class="d-flex justify-content-between text-muted small">
            <span><i class="fas fa-eye"></i> <%= art.views %></span>
            <span><i class="fas fa-clock"></i> <%= art.reading_time %> min</span>
          </div>

        </div>
      </div>
    </div>

    <% }) %>

  </div>

  <% } %>

</div>

<!-- Sidebar -->
<div class="col-lg-3">

  <div class="mb-4">
    <h6>Search</h6>
    <form action="/search">
      <input type="text" name="q" class="form-control" placeholder="Search...">
    </form>
  </div>

  <div>
    <h6>Categories</h6>
    <% categories.forEach(cat => { %>
      <div class="d-flex justify-content-between">
        <span><%= cat.name %></span>
        <span><%= cat.article_count %></span>
      </div>
    <% }) %>
  </div>

</div>
