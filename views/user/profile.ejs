<%- include('../partials/header', { title, user, currentPage }) %>
<div class="page-header">
  <div class="container">
    <h1><i class="fas fa-user-edit me-2"></i>My Profile</h1>
    <p>Manage your personal information and account settings</p>
  </div>
</div>
<div class="breadcrumb-section"><div class="container"><nav><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/"><i class="fas fa-home me-1"></i>Home</a></li><li class="breadcrumb-item"><a href="/user/dashboard">Dashboard</a></li><li class="breadcrumb-item active">Profile</li></ol></nav></div></div>
<div class="container py-5">
  <div class="row g-4">
    <div class="col-lg-4">
      <div class="bg-white rounded-3 shadow-sm p-4 text-center mb-4">
        <% if (profile.avatar_url) { %>
          <img src="<%= profile.avatar_url %>" class="rounded-circle mb-3" style="width:100px;height:100px;object-fit:cover">
        <% } else { %>
          <div style="width:100px;height:100px;border-radius:50%;background:linear-gradient(135deg,var(--primary),var(--primary-light));color:white;display:flex;align-items:center;justify-content:center;font-size:40px;font-weight:700;margin:0 auto 16px">
            <%= (profile.first_name||'U')[0] %>
          </div>
        <% } %>
        <h5 style="font-family:var(--font-display);font-weight:700"><%= profile.first_name %> <%= profile.last_name %></h5>
        <p class="text-muted mb-1" style="font-size:14px">@<%= profile.username %></p>
        <span class="badge bg-<%= profile.role==='admin'?'danger':'primary' %>"><%= profile.role %></span>
        <% if (profile.department) { %>
        <p class="mt-2 text-muted" style="font-size:13px"><i class="fas fa-university me-1"></i><%= profile.department %></p>
        <% } %>
        <% if (profile.student_id) { %>
        <p class="text-muted" style="font-size:13px"><i class="fas fa-id-card me-1"></i><%= profile.student_id %></p>
        <% } %>
        <hr>
        <div class="row g-2 text-center">
          <div class="col-6"><div class="p-2 rounded" style="background:var(--bg-light)"><div style="font-size:20px;font-weight:700;color:var(--primary)">—</div><div style="font-size:11px;color:var(--text-muted)">Articles</div></div></div>
          <div class="col-6"><div class="p-2 rounded" style="background:var(--bg-light)"><div style="font-size:20px;font-weight:700;color:var(--primary)"><%= new Date(profile.created_at).getFullYear() %></div><div style="font-size:11px;color:var(--text-muted)">Member Since</div></div></div>
        </div>
      </div>
    </div>
    <div class="col-lg-8">
      <% if (error) { %><div class="alert alert-danger alert-auto-dismiss mb-4"><i class="fas fa-exclamation-circle me-2"></i><%= error %></div><% } %>
      <% if (success) { %><div class="alert alert-success alert-auto-dismiss mb-4"><i class="fas fa-check-circle me-2"></i><%= success %></div><% } %>
      <div class="bg-white rounded-3 shadow-sm p-4 mb-4">
        <h6 style="font-family:var(--font-display);font-weight:700;color:var(--primary)" class="mb-4"><i class="fas fa-user me-2"></i>Personal Information</h6>
        <form action="/user/profile" method="POST">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label fw-600">First Name</label>
              <input type="text" name="first_name" class="form-control" value="<%= profile.first_name||'' %>" required>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-600">Last Name</label>
              <input type="text" name="last_name" class="form-control" value="<%= profile.last_name||'' %>" required>
            </div>
            <div class="col-12">
              <label class="form-label fw-600">Bio</label>
              <textarea name="bio" class="form-control" rows="4" placeholder="Tell us about yourself, your research interests..."><%= profile.bio||'' %></textarea>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-600">Department</label>
              <select name="department" class="form-select">
                <option value="">Select Department</option>
                <% ['Computer Science','Business Administration','Engineering','Arts & Humanities','Natural Sciences','Social Sciences','Law','Medicine & Health'].forEach(d => { %>
                <option <%= profile.department===d?'selected':'' %>><%= d %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-600">Student ID</label>
              <input type="text" name="student_id" class="form-control" value="<%= profile.student_id||'' %>">
            </div>
            <div class="col-12">
              <label class="form-label fw-600">Email <span class="text-muted">(cannot be changed)</span></label>
              <input type="email" class="form-control" value="<%= profile.email %>" disabled>
            </div>
            <div class="col-12">
              <button type="submit" class="btn btn-primary px-5"><i class="fas fa-save me-2"></i>Save Changes</button>
            </div>
          </div>
        </form>
      </div>
      <div class="bg-white rounded-3 shadow-sm p-4">
        <h6 style="font-family:var(--font-display);font-weight:700;color:var(--primary)" class="mb-3"><i class="fas fa-shield-alt me-2"></i>Account Security</h6>
        <p class="text-muted mb-3" style="font-size:14px">To change your password, use the forgot password feature.</p>
        <a href="/auth/forgot-password" class="btn btn-outline-secondary"><i class="fas fa-key me-2"></i>Change Password</a>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
